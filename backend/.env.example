# ── Mistral AI (required) ─────────────────────────────────────────────────────
# Get your key at https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed, file created automatically)
DATABASE_URL=sqlite+aiosqlite:///./openclaw.db

# Production (swap to PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/openclaw

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Fernet key for token encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-key-here

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=OpenClaw
APP_ENV=development
DIGEST_RECIPIENTS=manager@yourcompany.com

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback

# ── Web Search (optional) ─────────────────────────────────────────────────────
# No API key required — uses DuckDuckGo Instant Answer API via httpx.
# Risk classifier uses this to enrich Mistral context with real-world info.
WEB_SEARCH_ENABLED=true
